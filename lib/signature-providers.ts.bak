/**
 * Signature Providers - Options de signature électronique (GRATUITES et payantes)
 *
 * Ce fichier liste les options de signature électronique pour Factur-X.
 * Certaines sont gratuites, d'autres payantes mais avec offres d'essai.
 */

export interface SignatureProvider {
  id: string;
  name: string;
  type: 'api' | 'certificate' | 'software';
  pricing: 'free' | 'freemium' | 'paid';
  website: string;
  description: string;
  features: string[];
  limitations?: string;
  rgsCompliant: boolean;
}

