  openssl: {
    install: 'brew install openssl', // ou apt-get install openssl
    generate: `openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem -days 365`,
    usage: 'Tests uniquement - NON CONFORME POUR PRODUCTION'
  },

  docusign: {
    signup: 'https://developers.docusign.com',
    docs: 'https://developers.docusign.com/docs/esign-rest-api/reference/',
    npm: 'npm install docusign-esign',
    example: `const docusign = require('docusign-esign');
const apiClient = new docusign.ApiClient();
apiClient.addDefaultHeader('Authorization', 'Bearer ' + accessToken);`
  },

  yousign: {
    signup: 'https://yousign.com',
    docs: 'https://dev.yousign.com',
    npm: 'npm install yousign',
    example: `const Yousign = require('yousign');
const yousign = new Yousign({ apiKey: process.env.YOUSIGN_API_KEY });`
  },

  certigna: {
    purchase: 'https://www.certigna.fr/acheter',
    docs: 'https://www.certigna.fr/documentation',
    note: 'Acheter le certificat puis installer dans le navigateur/serveur'
  }
};

/**
 * Calcul du coût annuel selon les options
 */
export function calculateAnnualCost(
  providerId: string,
  volume: number // nombre de factures par an
): { minCost: number; maxCost: number; recommendation: string } {
  const provider = SIGNATURE_PROVIDERS.find(p => p.id === providerId);
  if (!provider) {
    return { minCost: 0, maxCost: 0, recommendation: 'Provider inconnu' };
  }

  switch (providerId) {
    case 'openssl':
      return {
        minCost: 0,
        maxCost: 0,
        recommendation: 'Gratuit mais NON CONFORME - Tests uniquement'
      };

    case 'docusign':
      if (volume <= 36) { // 3 par mois = 36 par an
        return {
          minCost: 0,
          maxCost: 0,
          recommendation: 'Offre gratuite suffisante'
        };
      }
      return {
        minCost: 300, // ~25€/mois
        maxCost: 600,
        recommendation: 'Passer à l\'offre payante au-delà de 3 factures/mois'
      };

    case 'certigna':
      return {
        minCost: 200,
        maxCost: 500,
        recommendation: 'Certificat RGS* - Obligatoire pour conformité stricte'
      };

    default:
      return {
        minCost: 0,
        maxCost: 0,
        recommendation: 'Contacter le provider pour un devis'
      };
  }
}
