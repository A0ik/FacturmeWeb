/**
 * Filtre les providers selon critères
 */
export function filterProviders(filters: {
  pricing?: 'free' | 'freemium' | 'paid' | 'all';
  rgsCompliant?: boolean;
  type?: 'api' | 'certificate' | 'software' | 'all';
}): SignatureProvider[] {
  return SIGNATURE_PROVIDERS.filter(provider => {
    if (filters.pricing && filters.pricing !== 'all' && provider.pricing !== filters.pricing) {
      return false;
    }
    if (filters.rgsCompliant !== undefined && provider.rgsCompliant !== filters.rgsCompliant) {
      return false;
    }
    if (filters.type && filters.type !== 'all' && provider.type !== filters.type) {
      return false;
    }
    return true;
  });
}

/**
 * Retourne les options gratuites uniquement
 */
export function getFreeProviders(): SignatureProvider[] {
  return filterProviders({ pricing: 'free' });
}

/**
 * Retourne les options freemium uniquement
 */
export function getFreemiumProviders(): SignatureProvider[] {
  return filterProviders({ pricing: 'freemium' });
}

/**
 * Retourne les options conformes RGS
 */
export function getRGSCompliantProviders(): SignatureProvider[] {
  return SIGNATURE_PROVIDERS.filter(p => p.rgsCompliant);
}

