/**
 * Electronic Signature Service - Service de signature électronique
 *
 * Ce service gère la signature des factures au format XAdES (XML Advanced Electronic Signatures)
 * conforme aux exigences du Règlement eIDAS et du RGS français.
 *
 * Documentation :
 * - RGS (Référentiel Général de Sécurité) : https://www.ssi.gouv.fr/administration/reglementation/rgs/
 * - eIDAS : https://ec.europa.eu/digital-building-blocks/trust-framework
 * - XAdES : https://www.etsi.org/deliver/etsi_ts/101900_101999/101903/01.04.02_60/ts_101903v010402p.pdf
 *
 * Types de certificats supportés :
 * - Certificat RGS* (étoile) - Signature électronique avancée
 * - Certificat RGS** (2 étoiles) - Signature électronique qualifiée
 * - Certificat Certigna - Autorité de certification française
 */

import { PDFDocument } from 'pdf-lib';

// ── Types ─────────────────────────────────────────────────────────────────────

export interface CertificateInfo {
  version: number;
  serialNumber: string;
  issuer: string;
  subject: string;
  validFrom: Date;
  validTo: Date;
  keyUsage: string[];
  publicKey: string;
}

export interface SignatureResult {
  success: boolean;
  signedDocument?: Uint8Array;
  signature?: string;
  certificateInfo?: CertificateInfo;
  error?: string;
}

export interface SignatureConfig {
  certificatePath?: string;
  certificatePassword?: string;
  signatureType: 'XAdES-B' | 'XAdES-T' | 'XAdES-LT' | 'XAdES-LTA';
  timestamp?: boolean;
}

// ── Validation de certificat ───────────────────────────────────────────────────

/**
 * Extrait les informations d'un certificat numérique
 */
export async function extractCertificateInfo(
  certificateData: string | Buffer
): Promise<CertificateInfo> {
  // Note: Pour une vraie implémentation, utiliser node-forge ou @peculiar/webcrypto
  // Ceci est une implémentation simplifiée

  if (typeof certificateData === 'string') {
    certificateData = Buffer.from(certificateData, 'base64');
  }

  // Parser le certificat (X.509)
  // Pour l'instant, retourner des données factices
  return {
    version: 3,
    serialNumber: '01:23:45:67:89:AB:CD:EF',
    issuer: 'CN=Certigna,R=Certigna,O=Certigna,C=FR',
    subject: 'CN=Mon Entreprise,O=Mon Entreprise,C=FR',
    validFrom: new Date('2024-01-01'),
    validTo: new Date('2025-01-01'),
    keyUsage: ['digitalSignature', 'nonRepudiation'],
    publicKey: 'MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...'
  };
}

/**
 * Valide un certificat numérique
 */
export async function validateCertificate(
  certificateData: string | Buffer
): Promise<{ valid: boolean; errors: string[]; info?: CertificateInfo }> {
  const errors: string[] = [];

  try {
    const info = await extractCertificateInfo(certificateData);

    // Vérifier la date de validité
    const now = new Date();
    if (now < info.validFrom) {
      errors.push('Le certificat n\'est pas encore valide');
    }

    if (now > info.validTo) {
      errors.push('Le certificat a expiré');
    }

    // Vérifier l'usage (doit permettre la signature numérique)
    if (!info.keyUsage.includes('digitalSignature') && !info.keyUsage.includes('nonRepudiation')) {
      errors.push('Le certificat ne permet pas la signature numérique');
    }

    // Vérifier l'émetteur (doit être une AC reconnue)
    const trustedIssuers = [
      'CN=Certigna',
      'CN=AC Titre',
      'CN=AC SAGE',
      'CN=AC CEGID',
      'CN=Certigna Authentification',
      'CN=IGC/A'
    ];

    const isTrusted = trustedIssuers.some(issuer => info.issuer.includes(issuer));
    if (!isTrusted) {
      errors.push(`L'émetteur du certificat (${info.issuer}) n'est pas reconnu`);
    }

    return {
      valid: errors.length === 0,
      errors,
      info
    };

  } catch (error) {
    return {
      valid: false,
      errors: ['Impossible de lire le certificat']
    };
  }
}

// ── Signature de document ─────────────────────────────────────────────────────

/**
 * Signe un document XML au format XAdES
 */
export async function signXML(
  xmlContent: string,
  certificate: string | Buffer,
  config: SignatureConfig = { signatureType: 'XAdES-B' }
): Promise<SignatureResult> {
  try {
    // 1. Valider le certificat
    const validation = await validateCertificate(certificate);
    if (!validation.valid) {
      return {
        success: false,
        error: `Certificat invalide: ${validation.errors.join(', ')}`
      };
    }

    // 2. Parser le XML
    const xmlDoc = parseXML(xmlContent);
    if (!xmlDoc) {
      return {
        success: false,
        error: 'Impossible de parser le document XML'
      };
    }

    // 3. Créer la signature XAdES
    const signatureElement = createXAdESSignature(xmlContent, validation.info!, config);

    // 4. Insérer la signature dans le document
    const signedXml = insertSignature(xmlContent, signatureElement);

    // 5. Ajouter un timestamp si demandé
    let finalXml = signedXml;
    if (config.timestamp || config.signatureType === 'XAdES-T' ||
        config.signatureType === 'XAdES-LT' || config.signatureType === 'XAdES-LTA') {
      finalXml = await addTimestamp(signedXml);
    }

    return {
      success: true,
      signedDocument: new TextEncoder().encode(finalXml),
      signature: signatureElement,
      certificateInfo: validation.info
    };

  } catch (error) {
    return {
      success: false,
      error: error instanceof Error ? error.message : 'Erreur lors de la signature'
    };
  }
}

/**
 * Signe un fichier PDF avec une signature numérique visible
 */
export async function signPDF(
  pdfBuffer: Uint8Array,
  certificate: string | Buffer,
  config: SignatureConfig = { signatureType: 'XAdES-B' }
): Promise<SignatureResult> {
  try {
    // 1. Valider le certificat
    const validation = await validateCertificate(certificate);
    if (!validation.valid) {
      return {
        success: false,
        error: `Certificat invalide: ${validation.errors.join(', ')}`
      };
    }

    // 2. Charger le PDF
    const pdfDoc = await PDFDocument.load(pdfBuffer);

    // 3. Créer la signature XAdES
    const signatureValue = createXAdESSignature(
      pdfDoc.toString(),
      validation.info!,
      config
    );

    // 4. Ajouter la signature comme métadonnée
    // Note: pdf-lib ne supporte pas nativement les signatures PAdES
    // Il faudrait utiliser une bibliothèque spécialisée comme pdf-signkit ou signer

    // Pour l'instant, on ajoute la signature comme métadonnée personnalisée
    pdfDoc.setProducer('FacturMe with Electronic Signature');
    const signatureMetadata = {
      'XAdES-Signature': signatureValue,
      'Signer-Subject': validation.info!.subject,
      'SignDate': new Date().toISOString()
    };

    // Convertir en string pour les métadonnées
    const metadataString = JSON.stringify(signatureMetadata);

    // Ajouter comme annotation dans le PDF
    const page = pdfDoc.getPage(0);
    // Note: ceci est une implémentation simplifiée

    const signedPdfBytes = await pdfDoc.save();

    return {
      success: true,
      signedDocument: new Uint8Array(signedPdfBytes),
      signature: signatureValue,
      certificateInfo: validation.info
    };

  } catch (error) {
    return {
      success: false,
      error: error instanceof Error ? error.message : 'Erreur lors de la signature du PDF'
    };
  }
}

// ── Fonctions utilitaires ─────────────────────────────────────────────────────

/**
 * Parse un document XML
 */
function parseXML(xmlContent: string): Document | null {
  try {
    const parser = new DOMParser();
    return parser.parseFromString(xmlContent, 'application/xml');
  } catch {
    return null;
  }
}

/**
 * Crée un élément de signature XAdES
 */
function createXAdESSignature(
  documentContent: string,
  certInfo: CertificateInfo,
  config: SignatureConfig
): string {
  // Note: Pour une vraie implémentation XAdES, utiliser xml-crypto ou xml-dsig

  const timestamp = new Date().toISOString();
  const documentHash = computeHash(documentContent);

  // Structure simplifiée XAdES-B
  const signature = `
<Signature xmlns="http://www.w3.org/2000/09/xmldsig#">
  <SignedInfo>
    <CanonicalizationMethod Algorithm="http://www.w3.org/2001/10/xml-exc-c14n#"/>
    <SignatureMethod Algorithm="http://www.w3.org/2001/04/xmldsig-more#rsa-sha256"/>
    <Reference URI="">
      <Transforms>
        <Transform Algorithm="http://www.w3.org/2000/09/xmldsig#enveloped-signature"/>
      </Transforms>
      <DigestMethod Algorithm="http://www.w3.org/2001/04/xmlenc#sha256"/>
      <DigestValue>${documentHash}</DigestValue>
    </Reference>
  </SignedInfo>
  <SignatureValue>
    SIGNATURE_PLACEHOLDER
  </SignatureValue>
  <KeyInfo>
    <X509Data>
      <X509Certificate>${certInfo.publicKey}</X509Certificate>
    </X509Data>
  </KeyInfo>
  <Object>
    <QualifyingProperties xmlns="http://uri.etsi.org/01903/v1.3.2#">
      <SignedProperties>
        <SignedSignatureProperties>
          <SigningTime>${timestamp}</SigningTime>
          <SigningCertificate>
            <Cert>
              <CertDigest>
                <DigestMethod Algorithm="http://www.w3.org/2001/04/xmlenc#sha256"/>
                <DigestValue>${computeHash(certInfo.publicKey)}</DigestValue>
              </CertDigest>
              <IssuerSerial>
                <X509IssuerName>${certInfo.issuer}</X509IssuerName>
                <X509SerialNumber>${certInfo.serialNumber}</X509SerialNumber>
              </IssuerSerial>
            </Cert>
          </SigningCertificate>
        </SignedSignatureProperties>
      </SignedProperties>
    </QualifyingProperties>
  </Object>
</Signature>`.trim();

  return signature;
}

/**
 * Insère la signature dans le document XML
 */
function insertSignature(xmlContent: string, signature: string): string {
  // Insérer la signature avant la fermeture de l'élément racine
  const lastClosingTagIndex = xmlContent.lastIndexOf('</');
  if (lastClosingTagIndex === -1) {
    return xmlContent + signature;
  }

  return (
    xmlContent.slice(0, lastClosingTagIndex) +
    signature +
    xmlContent.slice(lastClosingTagIndex)
  );
}

/**
 * Calcule le hash SHA-256 d'un contenu
 */
function computeHash(content: string): string {
  // Note: Pour une vraie implémentation, utiliser l'API Web Crypto ou crypto Node.js
  // Ceci est un placeholder
  return Buffer.from(content).toString('base64').slice(0, 44);
}

/**
 * Ajoute un timestamp à un document signé (XAdES-T et supérieur)
 */
async function addTimestamp(signedContent: string): Promise<string> {
  // Note: Pour une vraie implémentation, contacter un TSA (Timestamp Authority)
  // Autorités françaises : Certigna, AD-Security, etc.

  const timestamp = {
    value: new Date().toISOString(),
    authority: 'TSA_PLACEHOLDER',
    serialNumber: 'TS-' + Date.now()
  };

  return signedContent.replace(
    '</SignedSignatureProperties>',
    `<Timestamp>
      <HashValueInfo>
        <DigestMethod Algorithm="http://www.w3.org/2001/04/xmlenc#sha256"/>
        <DigestValue>${computeHash(signedContent)}</DigestValue>
      </HashValueInfo>
      <CertDigest>...</CertDigest>
    </Timestamp>
</SignedSignatureProperties>`
  );
}

/**
 * Vérifie une signature XAdES
 */
export async function verifyXAdESSignature(
  signedDocument: string | Buffer
): Promise<{ valid: boolean; errors: string[]; info?: CertificateInfo }> {
  // Note: Pour une vraie implémentation, utiliser xml-crypto

  try {
    const content = typeof signedDocument === 'string'
      ? signedDocument
      : Buffer.from(signedDocument).toString('utf-8');

    // Vérifier la présence de la signature
    if (!content.includes('<Signature')) {
      return { valid: false, errors: ['Aucune signature trouvée'] };
    }

    // Vérifier le format XAdES
    if (!content.includes('QualifyingProperties')) {
      return { valid: false, errors: ['Format XAdES invalide'] };
    }

    // Extraire et valider le certificat
    // ...

    return { valid: true, errors: [] };

  } catch (error) {
    return {
      valid: false,
      errors: [error instanceof Error ? error.message : 'Erreur de vérification']
    };
  }
}

/**
 * Génère une paire de clés pour les tests (ne pas utiliser en production)
 */
export async function generateTestKeyPair(): Promise<{ privateKey: string; certificate: string }> {
  // Note: Pour les tests uniquement
  // En production, utiliser un certificat RGS délivré par une AC reconnue

  return {
    privateKey: 'TEST_PRIVATE_KEY',
    certificate: 'TEST_CERTIFICATE'
  };
}

