# ─── SUPABASE ──────────────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── STRIPE ────────────────────────────────────────────────────────────────────
# Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard → Connect → Settings → Client ID
STRIPE_CLIENT_ID=ca_...

# Stripe Price IDs — create them in Dashboard → Products
STRIPE_SOLO_MONTHLY_PRICE_ID=price_...
STRIPE_SOLO_YEARLY_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# ─── GROQ (Transcription vocale Whisper) ───────────────────────────────────────
# console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# ─── OPENROUTER (IA parsing — modèles gratuits disponibles) ────────────────────
# openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ─── BREVO (Envoi d'emails) ─────────────────────────────────────────────────────
# app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=contact@votredomaine.com

# ─── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://facturme.vercel.app

# ─── WEB PUSH NOTIFICATIONS (PWA) ──────────────────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BNxxx...
VAPID_PRIVATE_KEY=xxx...
VAPID_SUBJECT=mailto:contact@votredomaine.com

# ─── CHORUS PRO (optionnel — facturation secteur public) ───────────────────────
# CHORUS_PRO_CLIENT_ID=
# CHORUS_PRO_CLIENT_SECRET=
# CHORUS_PRO_LOGIN=
# CHORUS_PRO_PASSWORD=

# ─── GOOGLE CALENDAR (optionnel — synchronisation agenda) ──────────────────────
# console.cloud.google.com → APIs & Services → Credentials
# 1. Créer un projet OAuth 2.0
# 2. Activer "Google Calendar API"
# 3. Créer un ID client OAuth avec URI de redirection autorisée
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URI de redirection (remplacer avec votre domaine en production)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
