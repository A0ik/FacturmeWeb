'use client';

import { useState } from 'react';
import {
  Shield, CheckCircle2, XCircle, AlertTriangle, Info, Lock,
  FileText, Clock, ExternalLink, ChevronDown, ChevronUp,
  Settings, AlertCircle, TrendingUp, Zap, Link as LinkIcon,
  Building2, Server, Award, FileCheck, ArrowRight
} from 'lucide-react';
import { motion, AnimatePresence } from 'framer-motion';
import { cn } from '@/lib/utils';

interface ComplianceItem {
  id: string;
  category: 'pdp' | 'security' | 'format' | 'integration';
  title: string;
  description: string;
  status: 'compliant' | 'partial' | 'missing' | 'optional';
  impact: 'critical' | 'high' | 'medium' | 'low';
  action?: {
    label: string;
    href: string;
  };
}

const COMPLIANCE_ITEMS: ComplianceItem[] = [
  // PDP - Plateforme de Dématérialisation Partagée
  {
    id: 'pdp-facturx',
    category: 'pdp',
    title: 'Format Factur-X (EN 16931)',
    description: 'Format hybride PDF + XML conforme à la norme européenne',
    status: 'compliant',
    impact: 'critical'
  },
  {
    id: 'pdp-fields',
    category: 'pdp',
    title: 'Champs obligatoires PDP',
    description: 'SIRET, TVA, adresse complète vendeur et client',
    status: 'partial',
    impact: 'critical',
    action: { label: 'Vérifier les champs', href: '/settings?tab=company' }
  },
  {
    id: 'pdp-transmission',
    category: 'pdp',
    title: 'Transmission PDP automatique',
    description: 'Envoi automatique à la plateforme de l\'État (DGFiP/Chorus Pro)',
    status: 'missing',
    impact: 'critical',
    action: { label: 'Configurer la transmission', href: '#pdp-setup' }
  },
  {
    id: 'pdp-chorus',
    category: 'pdp',
    title: 'Chorus Pro (B2G)',
    description: 'Facturation électronique pour les commandes publiques',
    status: 'missing',
    impact: 'high',
    action: { label: 'En savoir plus', href: 'https://chorus-pro.gouv.fr' }
  },

  // Sécurité
  {
    id: 'sec-signature',
    category: 'security',
    title: 'Signature électronique',
    description: 'Certificat de signature pour authentifier les factures',
    status: 'missing',
    impact: 'critical',
    action: { label: 'Configurer le certificat', href: '#certificate' }
  },
  {
    id: 'sec-audit',
    category: 'security',
    title: 'Logs d\'audit',
    description: 'Traçabilité complète des opérations de facturation',
    status: 'compliant',
    impact: 'high'
  },
  {
    id: 'sec-archivage',
    category: 'security',
    title: 'Archivage légal (10 ans)',
    description: 'Conservation sécurisée des factures selon le Code de Commerce',
    status: 'partial',
    impact: 'high',
    action: { label: 'Vérifier l\'archivage', href: '#storage' }
  },

  // Format
  {
    id: 'fmt-edigaso',
    category: 'format',
    title: 'Format EDIGASO',
    description: 'Format spécifique pour les factures B2G',
    status: 'missing',
    impact: 'medium',
    action: { label: 'Documentation', href: 'https://www.economie.gouv.fr' }
  },
  {
    id: 'fmt-validation',
    category: 'format',
    title: 'Validation automatique',
    description: 'Vérification de la conformité avant envoi',
    status: 'compliant',
    impact: 'medium'
  },

  // Intégrations
  {
    id: 'int-dgifp-api',
    category: 'integration',
    title: 'API DGFiP',
    description: 'Connexion directe à la plateforme de l\'État',
    status: 'missing',
    impact: 'critical',
    action: { label: 'Documentation API', href: 'https://www.dgfip.gouv.fr' }
  },
  {
    id: 'int-partners',
    category: 'integration',
    title: 'Partenaires PDP',
    description: 'Connexion aux plateformes agréées (Titre, SAGE, etc.)',
    status: 'optional',
    impact: 'low'
  }
];

const CATEGORY_INFO = {
  pdp: {
    label: 'PDP - Réforme 2026+',
    icon: Shield,
    color: 'text-indigo-600',
    bg: 'bg-indigo-50',
    border: 'border-indigo-200'
  },
  security: {
    label: 'Sécurité',
    icon: Lock,
    color: 'text-emerald-600',
    bg: 'bg-emerald-50',
    border: 'border-emerald-200'
  },
  format: {
    label: 'Format & Normes',
    icon: FileText,
    color: 'text-blue-600',
    bg: 'bg-blue-50',
    border: 'border-blue-200'
  },
  integration: {
    label: 'Intégrations API',
    icon: Server,
    color: 'text-purple-600',
    bg: 'bg-purple-50',
    border: 'border-purple-200'
  }
};

const STATUS_CONFIG = {
  compliant: {
    label: 'Conforme',
    icon: CheckCircle2,
    color: 'text-emerald-600',
    bg: 'bg-emerald-50',
    border: 'border-emerald-200'
  },
  partial: {
    label: 'Partiel',
    icon: AlertTriangle,
    color: 'text-amber-600',
    bg: 'bg-amber-50',
    border: 'border-amber-200'
  },
  missing: {
    label: 'Manquant',
    icon: XCircle,
    color: 'text-red-600',
    bg: 'bg-red-50',
    border: 'border-red-200'
  },
  optional: {
    label: 'Optionnel',
    icon: Info,
    color: 'text-gray-600',
    bg: 'bg-gray-50',
    border: 'border-gray-200'
  }
};

const IMPACT_LABELS = {
  critical: 'Critique',
  high: 'Important',
  medium: 'Moyen',
  low: 'Faible'
};

interface FacturXComplianceDashboardProps {
  mode?: 'full' | 'compact' | 'banner';
}

export function FacturXComplianceDashboard({ mode = 'full' }: FacturXComplianceDashboardProps) {
  const [expandedCategory, setExpandedCategory] = useState<string | null>(null);
  const [selectedImpact, setSelectedImpact] = useState<string>('all');

  const filteredItems = COMPLIANCE_ITEMS.filter(item =>
    selectedImpact === 'all' || item.impact === selectedImpact
  );

  const calculateScore = () => {
    const required = COMPLIANCE_ITEMS.filter(i => i.status !== 'optional');
    const compliant = required.filter(i => i.status === 'compliant').length;
    const partial = required.filter(i => i.status === 'partial').length;
    const total = required.length;

    const score = Math.round(((compliant + partial * 0.5) / total) * 100);
    return { score, compliant, partial, total };
  };

  const score = calculateScore();

  // Mode banner - compact pour affichage en haut de page
  if (mode === 'banner') {
    return (
      <motion.div
        initial={{ opacity: 0, y: -10 }}
        animate={{ opacity: 1, y: 0 }}
        className={cn(
          'rounded-xl border-2 p-4',
          score.score >= 75
            ? 'bg-emerald-50 border-emerald-200'
            : score.score >= 50
              ? 'bg-amber-50 border-amber-200'
              : 'bg-red-50 border-red-200'
        )}
      >
        <div className="flex items-center justify-between gap-4">
          <div className="flex items-center gap-3">
            {score.score >= 75 ? (
              <CheckCircle2 size={24} className="text-emerald-600" />
            ) : score.score >= 50 ? (
              <AlertTriangle size={24} className="text-amber-600" />
            ) : (
              <XCircle size={24} className="text-red-600" />
            )}
            <div>
              <p className="font-bold text-gray-900">
                Conformité Factur-X : {score.score}%
              </p>
              <p className="text-sm text-gray-600">
                {score.compliant}/{score.total} exigences conformes
              </p>
            </div>
          </div>
          <button
            onClick={() => setExpandedCategory('all')}
            className="px-4 py-2 rounded-lg bg-white hover:bg-gray-50 text-sm font-semibold transition-colors border border-gray-200"
          >
            Voir le détail
          </button>
        </div>
      </motion.div>
    );
  }

  // Mode compact - pour sidebar
  if (mode === 'compact') {
    return (
      <div className="bg-white rounded-xl border border-gray-200 p-4 space-y-3">
        <div className="flex items-center justify-between">
          <span className="text-sm font-bold text-gray-700">Score de conformité</span>
          <span className={cn(
            'text-lg font-black',
            score.score >= 75 ? 'text-emerald-600' : score.score >= 50 ? 'text-amber-600' : 'text-red-600'
          )}>
            {score.score}%
          </span>
        </div>
        <div className="w-full bg-gray-100 rounded-full h-2">
          <motion.div
            initial={{ width: 0 }}
            animate={{ width: `${score.score}%` }}
            transition={{ duration: 0.8, ease: 'easeOut' }}
            className={cn(
              'h-full rounded-full',
              score.score >= 75 ? 'bg-emerald-500' : score.score >= 50 ? 'bg-amber-500' : 'bg-red-500'
            )}
          />
        </div>
        <div className="flex items-center gap-2 text-xs text-gray-500">
          <Shield size={12} />
          <span>{score.compliant} conformes, {COMPLIANCE_ITEMS.filter(i => i.status === 'missing').length} manquants</span>
        </div>
      </div>
    );
  }

  // Mode full - dashboard complet
  return (
    <div className="space-y-6">
      {/* Header avec score */}
      <motion.div
        initial={{ opacity: 0, y: -10 }}
        animate={{ opacity: 1, y: 0 }}
        className="bg-gradient-to-br from-indigo-600 via-purple-600 to-indigo-700 rounded-2xl p-6 text-white shadow-xl"
      >
        <div className="flex items-start justify-between gap-6">
          <div className="flex-1">
            <div className="flex items-center gap-3 mb-3">
              <div className="p-2 bg-white/20 rounded-xl">
                <Shield size={24} />
              </div>
              <div>
                <h2 className="text-2xl font-black">Conformité Réforme 2026+</h2>
                <p className="text-indigo-100 text-sm">Facture électronique & PDP</p>
              </div>
            </div>
            <p className="text-indigo-100 text-sm max-w-xl">
              Suivez votre progression vers la conformité à la réforme de la facturation électronique.
              Certaines fonctionnalités sont critiques pour éviter les pénalités.
            </p>
          </div>

          {/* Score circulaire */}
          <div className="flex-shrink-0 text-center">
            <div className="relative w-28 h-28">
              <svg className="w-full h-full transform -rotate-90">
                <circle
                  cx="56"
                  cy="56"
                  r="48"
                  stroke="rgba(255,255,255,0.2)"
                  strokeWidth="12"
                  fill="none"
                />
                <motion.circle
                  cx="56"
                  cy="56"
                  r="48"
                  stroke="white"
                  strokeWidth="12"
                  fill="none"
                  strokeDasharray={`${2 * Math.PI * 48}`}
                  strokeDashoffset={`${2 * Math.PI * 48 * (1 - score.score / 100)}`}
                  strokeLinecap="round"
                  initial={{ strokeDashoffset: 2 * Math.PI * 48 }}
                  animate={{ strokeDashoffset: 2 * Math.PI * 48 * (1 - score.score / 100) }}
                  transition={{ duration: 1, ease: 'easeOut' }}
                />
              </svg>
              <div className="absolute inset-0 flex items-center justify-center">
                <span className="text-3xl font-black">{score.score}%</span>
              </div>
            </div>
            <p className="text-xs text-indigo-100 mt-2">de conformité</p>
          </div>
        </div>

        {/* Statistiques rapides */}
        <div className="grid grid-cols-4 gap-4 mt-6 pt-6 border-t border-white/20">
          <div className="text-center">
            <div className="text-2xl font-black">{score.compliant}</div>
            <div className="text-xs text-indigo-100">Conformes</div>
          </div>
          <div className="text-center">
            <div className="text-2xl font-black">{COMPLIANCE_ITEMS.filter(i => i.status === 'partial').length}</div>
            <div className="text-xs text-indigo-100">Partiels</div>
          </div>
          <div className="text-center">
            <div className="text-2xl font-black">{COMPLIANCE_ITEMS.filter(i => i.status === 'missing' && i.impact === 'critical').length}</div>
            <div className="text-xs text-indigo-100">Critiques</div>
          </div>
          <div className="text-center">
            <div className="text-2xl font-black">{COMPLIANCE_ITEMS.filter(i => i.status === 'missing').length}</div>
            <div className="text-xs text-indigo-100">Manquants</div>
          </div>
        </div>
      </motion.div>

      {/* Filtres par impact */}
      <div className="flex items-center gap-2 flex-wrap">
        <button
          onClick={() => setSelectedImpact('all')}
          className={cn(
            'px-4 py-2 rounded-lg text-sm font-semibold transition-all',
            selectedImpact === 'all'
              ? 'bg-gray-900 text-white'
              : 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-200'
          )}
        >
          Tous
        </button>
        <button
          onClick={() => setSelectedImpact('critical')}
          className={cn(
            'px-4 py-2 rounded-lg text-sm font-semibold transition-all',
            selectedImpact === 'critical'
              ? 'bg-red-600 text-white'
              : 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-200'
          )}
        >
          Critiques
        </button>
        <button
          onClick={() => setSelectedImpact('high')}
          className={cn(
            'px-4 py-2 rounded-lg text-sm font-semibold transition-all',
            selectedImpact === 'high'
              ? 'bg-amber-500 text-white'
              : 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-200'
          )}
        >
          Importants
        </button>
      </div>

      {/* Liste des catégories */}
      {Object.entries(CATEGORY_INFO).map(([categoryKey, categoryInfo]) => {
        const categoryItems = filteredItems.filter(item => item.category === categoryKey);
        if (categoryItems.length === 0) return null;

        const CategoryIcon = categoryInfo.icon;
        const isExpanded = expandedCategory === categoryKey;

        return (
          <motion.div
            key={categoryKey}
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: 1, y: 0 }}
            className="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden"
          >
            <button
              onClick={() => setExpandedCategory(isExpanded ? null : categoryKey)}
              className="w-full px-6 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors"
            >
              <div className="flex items-center gap-3">
                <div className={cn('p-2 rounded-xl', categoryInfo.bg)}>
                  <CategoryIcon size={20} className={categoryInfo.color} />
                </div>
                <span className="font-bold text-gray-900">{categoryInfo.label}</span>
                <span className="text-sm text-gray-500">
                  ({categoryItems.filter(i => i.status === 'compliant').length}/{categoryItems.length})
                </span>
              </div>
              {isExpanded ? (
                <ChevronUp size={20} className="text-gray-400" />
              ) : (
                <ChevronDown size={20} className="text-gray-400" />
              )}
            </button>

            <AnimatePresence>
              {isExpanded && (
                <motion.div
                  initial={{ height: 0, opacity: 0 }}
                  animate={{ height: 'auto', opacity: 1 }}
                  exit={{ height: 0, opacity: 0 }}
                  transition={{ duration: 0.2 }}
                  className="border-t border-gray-100"
                >
                  <div className="p-6 space-y-4">
                    {categoryItems.map((item) => {
                      const statusConfig = STATUS_CONFIG[item.status];
                      const StatusIcon = statusConfig.icon;

                      return (
                        <motion.div
                          key={item.id}
                          initial={{ opacity: 0, x: -10 }}
                          animate={{ opacity: 1, x: 0 }}
                          className={cn(
                            'p-4 rounded-xl border-2',
                            statusConfig.border,
                            statusConfig.bg
                          )}
                        >
                          <div className="flex items-start gap-4">
                            <div className="flex-shrink-0 mt-0.5">
                              <StatusIcon size={20} className={statusConfig.color} />
                            </div>
                            <div className="flex-1">
                              <div className="flex items-start justify-between gap-4">
                                <div>
                                  <h4 className="font-bold text-gray-900 mb-1">{item.title}</h4>
                                  <p className="text-sm text-gray-600">{item.description}</p>
                                </div>
                                <div className="flex flex-col items-end gap-2">
                                  <span className={cn(
                                    'text-xs font-bold px-2 py-1 rounded-full',
                                    statusConfig.bg,
                                    statusConfig.color
                                  )}>
                                    {statusConfig.label}
                                  </span>
                                  <span className={cn(
                                    'text-[10px] font-semibold px-2 py-0.5 rounded-full',
                                    item.impact === 'critical' ? 'bg-red-100 text-red-700' :
                                      item.impact === 'high' ? 'bg-amber-100 text-amber-700' :
                                        item.impact === 'medium' ? 'bg-blue-100 text-blue-700' :
                                          'bg-gray-100 text-gray-700'
                                  )}>
                                    {IMPACT_LABELS[item.impact]}
                                  </span>
                                </div>
                              </div>
                              {item.action && (
                                <a
                                  href={item.action.href}
                                  target={item.action.href.startsWith('http') ? '_blank' : undefined}
                                  rel={item.action.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                                  className="inline-flex items-center gap-2 mt-3 text-sm font-semibold text-primary hover:text-primary-dark transition-colors"
                                >
                                  {item.action.label}
                                  <ArrowRight size={14} />
                                </a>
                              )}
                            </div>
                          </div>
                        </motion.div>
                      );
                    })}
                  </div>
                </motion.div>
              )}
            </AnimatePresence>
          </motion.div>
        );
      })}

      {/* Actions rapides */}
      <motion.div
        initial={{ opacity: 0, y: 10 }}
        animate={{ opacity: 1, y: 0 }}
        className="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl border border-blue-200 p-6"
      >
        <h3 className="font-bold text-gray-900 mb-4 flex items-center gap-2">
          <Zap size={18} className="text-blue-600" />
          Actions recommandées
        </h3>
        <div className="space-y-3">
          {COMPLIANCE_ITEMS.filter(i => i.status === 'missing' && i.impact === 'critical').slice(0, 3).map((item) => (
            <a
              key={item.id}
              href={item.action?.href || '#'}
              className="flex items-center gap-3 p-3 bg-white rounded-xl hover:bg-blue-50 transition-colors border border-blue-100 group"
            >
              <div className="p-2 bg-red-100 rounded-lg">
                <AlertCircle size={16} className="text-red-600" />
              </div>
              <div className="flex-1">
                <p className="text-sm font-semibold text-gray-900">{item.title}</p>
                <p className="text-xs text-gray-500">Critique - À implémenter urgemment</p>
              </div>
              <ArrowRight size={16} className="text-gray-400 group-hover:text-blue-600 transition-colors" />
            </a>
          ))}
        </div>
      </motion.div>

      {/* Ressources externes */}
      <motion.div
        initial={{ opacity: 0, y: 10 }}
        animate={{ opacity: 1, y: 0 }}
        className="bg-white rounded-2xl border border-gray-200 p-6"
      >
        <h3 className="font-bold text-gray-900 mb-4 flex items-center gap-2">
          <ExternalLink size={18} className="text-primary" />
          Ressources officielles
        </h3>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
          <a
            href="https://www.economie.gouv.fr/facture-electronique"
            target="_blank"
            rel="noopener noreferrer"
            className="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors border border-gray-100 group"
          >
            <Building2 size={18} className="text-gray-400 group-hover:text-primary transition-colors" />
            <div className="flex-1">
              <p className="text-sm font-semibold text-gray-900">economie.gouv.fr</p>
              <p className="text-xs text-gray-500">Réforme facture électronique</p>
            </div>
            <ExternalLink size={14} className="text-gray-400" />
          </a>
          <a
            href="https://fnfe-mpe.org/factur-x/"
            target="_blank"
            rel="noopener noreferrer"
            className="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors border border-gray-100 group"
          >
            <FileCheck size={18} className="text-gray-400 group-hover:text-primary transition-colors" />
            <div className="flex-1">
              <p className="text-sm font-semibold text-gray-900">FNFE-MPE</p>
              <p className="text-xs text-gray-500">Comité Français Factur-X</p>
            </div>
            <ExternalLink size={14} className="text-gray-400" />
          </a>
          <a
            href="https://chorus-pro.gouv.fr"
            target="_blank"
            rel="noopener noreferrer"
            className="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors border border-gray-100 group"
          >
            <Server size={18} className="text-gray-400 group-hover:text-primary transition-colors" />
            <div className="flex-1">
              <p className="text-sm font-semibold text-gray-900">Chorus Pro</p>
              <p className="text-xs text-gray-500">Facturation B2G</p>
            </div>
            <ExternalLink size={14} className="text-gray-400" />
          </a>
          <a
            href="https://www.dgfip.gouv.fr"
            target="_blank"
            rel="noopener noreferrer"
            className="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors border border-gray-100 group"
          >
            <Award size={18} className="text-gray-400 group-hover:text-primary transition-colors" />
            <div className="flex-1">
              <p className="text-sm font-semibold text-gray-900">DGFiP</p>
              <p className="text-xs text-gray-500">API PDP</p>
            </div>
            <ExternalLink size={14} className="text-gray-400" />
          </a>
        </div>
      </motion.div>
    </div>
  );
}

export default FacturXComplianceDashboard;
